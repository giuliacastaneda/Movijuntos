@model IEnumerable<Web_App_Movijuntos.Models.Local>

@{
    Layout = "_Layout";

    ViewData["Title"] = "Local";
}

<h1>Locais</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Cadastrar novo local</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Endereco)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Endereco)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdLocal">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdLocal">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdLocal">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
