@model Web_App_Movijuntos.Models.Criterio

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Criterio</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdCriterio" />
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Rampas" /> @Html.DisplayNameFor(model => model.Rampas)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Corrimaos" /> @Html.DisplayNameFor(model => model.Corrimaos)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="BanheiroAcess" /> @Html.DisplayNameFor(model => model.BanheiroAcess)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="VagasEstacion" /> @Html.DisplayNameFor(model => model.VagasEstacion)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="SinalizacaoTatil" /> @Html.DisplayNameFor(model => model.SinalizacaoTatil)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="SinalizacaoSonora" /> @Html.DisplayNameFor(model => model.SinalizacaoSonora)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="SinalizaçãoVisual" /> @Html.DisplayNameFor(model => model.SinalizaçãoVisual)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="CaminhoLivre" /> @Html.DisplayNameFor(model => model.CaminhoLivre)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="PortasCorredor" /> @Html.DisplayNameFor(model => model.PortasCorredor)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="IdAvaliacao" class="control-label"></label>
                <select asp-for="IdAvaliacao" class="form-control" asp-items="ViewBag.IdAvaliacao"></select>
                <span asp-validation-for="IdAvaliacao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
