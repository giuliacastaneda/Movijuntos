@model Web_App_Movijuntos.Models.Avaliacao

@{
    ViewData["Title"] = "Cadastrar Avaliação";
}

<h1>Cadastrar Avaliação</h1>

<h4>Avaliacao</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Data" class="control-label"></label>
                <input asp-for="Data" class="form-control" />
                <span asp-validation-for="Data" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Nota" class="control-label"></label>
                <input asp-for="Nota" class="form-control" />
                <span asp-validation-for="Nota" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdLocal" class="control-label"></label>
                <select asp-for="IdLocal" class ="form-control" asp-items="ViewBag.IdLocal"></select>
            </div>
            <div class="form-group">
                <a class="btn btn-info" asp-action="Index">Voltar</a> |
                <button type="submit" class="btn btn-primary">Criar</button>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
